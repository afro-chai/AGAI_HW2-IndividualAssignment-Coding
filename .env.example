# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
# Speed/quality knobs (optional)
OLLAMA_NUM_PREDICT=220
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0.2

# Alpha Vantage (news sentiment) — https://www.alphavantage.co/documentation/
ALPHAVANTAGE_API_KEY=
# Optional: gitignored raw key file (first line only). See secrets/README.md
# Default path if unset: secrets/alphavantage_api_key.txt
# ALPHAVANTAGE_KEY_FILE=secrets/alphavantage_api_key.txt
# Optional NEWS_SENTIMENT tuning (see docs/ALPHA_VANTAGE.md)
# ALPHAVANTAGE_NEWS_LIMIT=20
# ALPHAVANTAGE_NEWS_SORT=LATEST
# Optional: seconds between AV HTTP calls if you hit free-tier rate limits (~5/min typical)
# ALPHAVANTAGE_MIN_INTERVAL_SEC=0

# Optional: LiteLLM OpenAI-compatible proxy (capstone / multi-provider)
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_MODEL=ollama/llama3.2
# LITELLM_API_KEY=litellm
