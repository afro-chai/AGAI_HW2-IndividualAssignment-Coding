.venv/
__pycache__/
*.pyc
.env
*.egg-info/
.pytest_cache/

# Local planning notes (not required for submission)
PLAN.md

# Report helper files (build locally if needed)
report/LATEX_BUILD.md
report/report_checklist.md

# Run transcripts (keep folder stubs only)
logs/*
!logs/README.md
!logs/.gitkeep

# Secrets: ignore contents; keep README for path documentation
secrets/*
!secrets/README.md

# Optional raw key file (legacy path)
secrets/alphavantage_api_key.txt

# May show API key in a screenshot — keep local only
docs/assets/alphavantage-welcome.png

# Local assignment brief / notes (not part of submission tree)
Instructions/

# Note: `scripts/` and `docs/` remain tracked so graders can run helpers and read supplemental docs.
